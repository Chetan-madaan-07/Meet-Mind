# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/meetmind

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# Google OAuth (for code exchange flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Server
HOST=0.0.0.0
PORT=8000
